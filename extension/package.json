{
  "name": "code-understanding-tracker",
  "displayName": "Code Understanding Tracker",
  "description": "Highlight code sections you understand and build a mind map of your knowledge",
  "version": "0.1.0",
  "publisher": "arpit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeTracker.markUnderstood",
        "title": "✅ Mark as Understood",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.markPartial",
        "title": "🟡 Mark as Partially Understood",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.unmark",
        "title": "❌ Remove Understanding Mark",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.addNote",
        "title": "📝 Add Note to Selection",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.exportMindMap",
        "title": "🗺️ Export Mind Map (Mermaid)",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.showStats",
        "title": "📊 Show Understanding Stats",
        "category": "Code Tracker"
      },
      {
        "command": "codeTracker.clearFile",
        "title": "Clear All Marks in File",
        "category": "Code Tracker"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "codeTracker.submenu",
          "group": "codeTracker"
        }
      ],
      "codeTracker.submenu": [
        {
          "command": "codeTracker.markUnderstood",
          "when": "editorHasSelection"
        },
        {
          "command": "codeTracker.markPartial",
          "when": "editorHasSelection"
        },
        {
          "command": "codeTracker.unmark",
          "when": "editorHasSelection"
        },
        {
          "command": "codeTracker.addNote",
          "when": "editorHasSelection"
        }
      ]
    },
    "submenus": [
      {
        "id": "codeTracker.submenu",
        "label": "🧠 Code Understanding"
      }
    ],
    "keybindings": [
      {
        "command": "codeTracker.markUnderstood",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "editorHasSelection"
      },
      {
        "command": "codeTracker.markPartial",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeTracker",
          "title": "Code Understanding",
          "icon": "$(brain)"
        }
      ]
    },
    "views": {
      "codeTracker": [
        {
          "id": "codeTracker.statsView",
          "name": "Understanding Overview"
        },
        {
          "id": "codeTracker.treeView",
          "name": "Marked Sections"
        }
      ]
    },
    "configuration": {
      "title": "Code Understanding Tracker",
      "properties": {
        "codeTracker.understoodColor": {
          "type": "string",
          "default": "rgba(34, 197, 94, 0.12)",
          "description": "Background color for understood sections"
        },
        "codeTracker.partialColor": {
          "type": "string",
          "default": "rgba(234, 179, 8, 0.12)",
          "description": "Background color for partially understood sections"
        },
        "codeTracker.understoodBorderColor": {
          "type": "string",
          "default": "rgba(34, 197, 94, 0.5)",
          "description": "Left border color for understood sections"
        },
        "codeTracker.partialBorderColor": {
          "type": "string",
          "default": "rgba(234, 179, 8, 0.5)",
          "description": "Left border color for partially understood sections"
        }
      }
    },
    "colors": [
      {
        "id": "codeTracker.understoodBackground",
        "description": "Background color for understood code",
        "defaults": {
          "dark": "rgba(34, 197, 94, 0.12)",
          "light": "rgba(34, 197, 94, 0.08)"
        }
      },
      {
        "id": "codeTracker.partialBackground",
        "description": "Background color for partially understood code",
        "defaults": {
          "dark": "rgba(234, 179, 8, 0.12)",
          "light": "rgba(234, 179, 8, 0.08)"
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
